# Required
# Bearer token for /admin/* routes
ACCESS_KEY=your-secret-key-here

# Optional
# HTTP listen port (default: 8080)
PORT=8080

# SQLite database file path (default: ./llmate.db)
DB_PATH=./llmate.db

# Period between health check ticks (default: 30s)
HEALTH_INTERVAL=30s

# slog level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Log output format: text or json (default: text)
LOG_FORMAT=text

# Maximum request body size in bytes (default: 10485760 = 10 MiB)
MAX_BODY_SIZE=10485760
